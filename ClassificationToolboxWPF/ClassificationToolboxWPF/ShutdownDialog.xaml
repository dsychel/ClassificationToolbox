<Window x:Class="ClassificationToolboxWPF.ShutdownDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClassificationToolboxWPF"
        mc:Ignorable="d"
        Height="100" Width="300" WindowStyle="ToolWindow" Title="Shutdown" >
    <Grid>
        <Label x:Name="messageLabel" Content="System will shutdown in 10s." HorizontalAlignment="Left" VerticalAlignment="Top" />
        <Button x:Name="cancelButton" Content="Cancel" HorizontalAlignment="Left" Margin="207,40,0,0" VerticalAlignment="Top" Width="75" Click="CancelButton_Click"/>
        <Button x:Name="okButton" Content="Ok" HorizontalAlignment="Left" Margin="119,40,0,0" VerticalAlignment="Top" Width="75" Click="OkButton_Click"/>
    </Grid>
</Window>
